# =============================================================================
# SECRETS & CREDENTIALS (CRITICAL - DO NOT REMOVE OR WEAKEN)
# This MCP handles highly sensitive trading credentials:
#   PK (private key), CLOB_API_KEY, CLOB_SECRET, CLOB_PASS_PHRASE,
#   RELAYER_API_KEY, BUILDER_* keys, FUNDER addresses, etc.
#
# Any file that could contain real CLOB / Polymarket / wallet credentials
# MUST be ignored. Never commit real secrets.
# =============================================================================

# Ignore ALL real .env* files (very broad on purpose for safety)
# This catches .env, .env.local, .env.production, .envrc, myapp.env, etc.
.env*
*.env

# EXCEPTION: Only these safe template files are allowed (and must stay placeholder-only)
!.env.example
!.env.template
!.env.sample
!*.env.example

# Protect common secret / wallet / credential file patterns
secrets/
*.pem
*.key
*.p12
*.pfx
wallet*.json
private*.json
clob*.json
*credentials*
*secret*

# Agent / MCP harness config files that commonly contain real env blocks
# (users put PK + CLOB_* directly inside mcp_servers entries)
config.yaml
config.yml
hermes*.yaml
hermes*.yml
mcp*.yaml
mcp*.yml
*config*.yaml
*config*.yml

# Python dotenv / config that people sometimes use for local testing
settings.local.py
local_settings.py

