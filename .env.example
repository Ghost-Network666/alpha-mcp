# =============================================================================
# polymarket-alpha MCP - Environment Variables Template
# =============================================================================
#
# AGENT INSTRUCTIONS:
# 1. Copy/rename this file:
#      cp .env.example .env     (or on Windows: copy .env.example .env)
# 2. Open the new .env file
# 3. Replace EVERY placeholder value below with your real credentials
# 4. Save the file
#
# ⚠️  NEVER commit the real .env file. It is already ignored by .gitignore.
#
# For Hermes / OpenClaw and similar agent harnesses:
#   The STRONGLY PREFERRED pattern is to put the real values (or ${VAR} references)
#   directly inside the mcp_servers.env block in your agent's config.yaml.
#   See the output of: polymarket_alpha_setup_guide(platform="hermes")
#
# Official recommended variable names (CLOB native flow):
#   PK, CLOB_API_KEY, CLOB_SECRET, CLOB_PASS_PHRASE
#
# These are the variables the MCP primarily reads for CLOB trading.
# =============================================================================

# -----------------------------------------------------------------------------
# CLOB TRADING CREDENTIALS — REPLACE THESE WITH REAL VALUES
# -----------------------------------------------------------------------------
# IMPORTANT FOR AGENTS:
# Replace the values below with your actual secrets, then save as .env

# PK = Your L1 private key (the EOA that signs)
PK=0xREPLACE_WITH_YOUR_REAL_PRIVATE_KEY

# CLOB_* = Pre-generated L2 API credentials (recommended)
# Get these from Polymarket website → Profile → API Keys (or similar)
CLOB_API_KEY=REPLACE_WITH_YOUR_REAL_CLOB_API_KEY
CLOB_SECRET=REPLACE_WITH_YOUR_REAL_CLOB_SECRET
CLOB_PASS_PHRASE=REPLACE_WITH_YOUR_REAL_CLOB_PASSPHRASE

# Optional: override the CLOB endpoint (defaults to production)
CLOB_API_URL=https://clob.polymarket.com

# Optional but often required for signature_type=3 (Deposit wallets):
# This must be your DEPOSIT WALLET address (not your EOA), visible at
# polymarket.com → Profile → Wallet
FUNDER=0xREPLACE_WITH_YOUR_REAL_DEPOSIT_WALLET_ADDRESS

# -----------------------------------------------------------------------------
# Legacy Variable Names (still supported)
# -----------------------------------------------------------------------------
# POLYMARKET_PRIVATE_KEY=0xYourPrivateKeyHere
# POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# -----------------------------------------------------------------------------
# Gasless / Builder Program / Relayer (only needed for on-chain gasless actions)
# -----------------------------------------------------------------------------
# RELAYER_API_KEY=your_relayer_key
# RELAYER_API_KEY_ADDRESS=0x...
# RELAYER_API_SECRET=...
# RELAYER_API_PASSPHRASE=...
# BUILDER_API_KEY=...
# BUILDER_SECRET=...
# BUILDER_PASSPHRASE=...
# POLY_SIGNATURE_TYPE=3          # 1=proxy, 2=Safe, 3=Deposit (default)

# Optional builder code for rewards tracking
# BUILDER_CODE=your_builder_code

# -----------------------------------------------------------------------------
# Other optional settings
# -----------------------------------------------------------------------------
# POLYGON_RPC_URL=https://polygon-rpc.com
# POLYMARKET_CHAIN_ID=137
# RELAYER_URL=https://relayer-v2.polymarket.com

# =============================================================================
# SECURITY NOTES
# =============================================================================
# - Real private keys (PK / POLYMARKET_PRIVATE_KEY) must never be shared or committed.
# - CLOB L2 secrets (CLOB_SECRET) are equivalent to trading keys — treat as secret.
# - The .gitignore in this repo is configured to ignore .env, *.env, config.yaml,
#   secrets/, and common places where people store real credentials.
# - When contributing or editing docs: only ever use placeholder values such as
#   ${PK}, 0xYourPrivateKeyHere, your_clob_api_key_here, etc.
# - If you ever accidentally commit a secret, rotate the keys immediately.
# =============================================================================
